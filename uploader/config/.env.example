# -------------------------------------------------------
# Copy this file to config/.env and fill in your values.
# NEVER commit the real .env to version control.
# -------------------------------------------------------

# Path to your Google service account JSON key file
GOOGLE_CREDENTIALS_PATH=config/credentials.json

# SoundCloud OAuth 2.0 credentials
# Register an app at https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret
SOUNDCLOUD_USERNAME=your_soundcloud_username
SOUNDCLOUD_PASSWORD=your_soundcloud_password

# SMTP credentials for error alert emails
SMTP_USERNAME=alerts@yourstation.com
SMTP_PASSWORD=your_smtp_app_password
